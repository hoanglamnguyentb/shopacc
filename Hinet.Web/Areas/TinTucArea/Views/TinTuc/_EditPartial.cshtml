@using Hinet.Model.IdentityEntities
@using Hinet.Model.IdentityEntities
@using Hinet.Web.Areas.TinTucArea.Models

@model EditVM
@{

}
<div class="modal-dialog">
    @using (Ajax.BeginForm("Edit", "TinTuc", new { @area = "TinTucArea" }, new AjaxOptions()
    {
        HttpMethod = "POST",
        OnFailure = "AjaxFormError",
        OnSuccess = "AjaxFormSuccess",
    }, new { id = "editTinTucForm", enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        //HtmlHelper.UnobtrusiveJavaScriptEnabled = false;
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <div class="center">
                    <h4 class="modal-title">Cập nhật </h4>
                </div>
            </div>
            <div class="modal-body">
                <div class="form-horizontal">
                    @Html.HiddenFor(x => x.Id)
                    <div class="form-group">
                        <label class="control-label col-sm-4">Slug <span class="red">*</span></label>
                        <div class="col-sm-8">
                            @Html.TextBoxFor(m => m.Slug, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.Slug, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label col-sm-4">Tiêu đề <span class="red">*</span></label>
                        <div class="col-sm-8">
                            @Html.TextBoxFor(m => m.TieuDe, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.TieuDe, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label col-sm-4">Nội dung </label>
                        <div class="col-sm-8">
                            @Html.TextBoxFor(m => m.NoiDung, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.NoiDung, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label col-sm-4">Ảnh bìa </label>
                        <div class="col-sm-8">
                            @Html.TextBoxFor(m => m.AnhBia, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.AnhBia, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label col-sm-4">Tác giả </label>
                        <div class="col-sm-8">
                            @Html.TextBoxFor(m => m.TacGia, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.TacGia, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label col-sm-4">Trạng thái </label>
                        <div class="col-sm-8">
                            @Html.TextBoxFor(m => m.TrangThai, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.TrangThai, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label col-sm-4">Thời gian xuất bản <span class="red">*</span></label>
                        <div class="col-sm-8">
                            @Html.TextBoxFor(m => m.ThoiGianXuatBan, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.ThoiGianXuatBan, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer center">
                <button type="submit" class="btn btn-primary">Hoàn thành</button>

                <button type="button" class="btn btn-default" data-dismiss="modal">Đóng</button>
            </div>
        </div>
    }
</div>
<script>
</script>
@Scripts.Render("~/bundles/jqueryval")