<div id="collapseDiv" class="panel-collapse collapse" aria-expanded="false" role="tabpanel">
    <div class="well SearchBox">

        @using (Ajax.BeginForm("searchData", "QLLogXuLy", new { Area = "QLLogXuLyArea" },
            new AjaxOptions()
            {
                HttpMethod = "POST",
                OnFailure = "AjaxFormError",
                OnSuccess = "AjaxSearchSuccess",
            }, new { }))
        {
            @Html.AntiForgeryToken()
            <div class="row row-block">

                @*<div class="col-md-6 row-block">
                    <div class="col-md-4 txt-label">Người tạo</div>
                    <div class="col-md-8">
                        @Html.DropDownList("NguoiTaoFilter", ViewBag.NguoiTaoFilter as List<SelectListItem>, "-- Tất cả --", new { @class = "form-control select2" })
                    </div>
                </div>*@

                <div class="col-md-6 row-block">
                    <div class="col-md-4 txt-label">Nội Dung</div>
                    <div class="col-md-8">
                        <input class="form-control width100" type="text" name="NoiDungFilter" />
                    </div>
                </div>

                <div class="col-md-6 row-block">
                    <div class="col-md-4 txt-label">Ngày bắt đầu</div>
                    <div class="col-md-8">
                        <input type="text" class="form-control width100" name="NgayFormFilter" id="NgayFormFilter" />
                    </div>
                </div>

                <div class="col-md-6 row-block">
                    <div class="col-md-4 txt-label">Ngày kết thúc</div>
                    <div class="col-md-8">
                        <input type="text" class="form-control width100" name="NgayEndFilter" id="NgayEndFilter" />
                    </div>
                </div>

                <div class="col-md-12 center" style=" margin-top:20px;">
                    <button id="btnSearch" type="submit" class="btn btn-labeled btn-primary btn-sm">
                        <span class="btn-label">
                            <i class="glyphicon glyphicon-search"></i>
                        </span>
                        Tìm kiếm
                    </button>
                    <a href="/QLLogXuLyArea/QLLogXuLy/ExportExcel" class="btn btn-labeled btn-success btn-sm"><span class='btn-label'><i class='glyphicon glyphicon-download'></i></span> Xuất Excel</a>
                    <a aria-expanded="false" href="#collapseDiv" data-toggle="collapse" role="button" class="btn btn-labeled btn-danger btn-sm">
                        <span class="btn-label"><i class="bi bi-x-lg"></i></span>
                        Đóng
                    </a>
                </div>
            </div>

        }
    </div>
</div>

<script>

    $('.select2').select2();
    $("#NgayFromFilter").datepicker({
        format: 'dd/mm/yyyy',
        autoclose: true,
        todayBtn: true,
        todayHighlight: true
    });

    $("#NgayFromFilter").on("blur", function () {
        if ($(this).val().trim() === "") {
            $(this).datepicker("setDate", null);
        }
    });
    $("#NgayEndFilter").datepicker({
        format: 'dd/mm/yyyy',
        autoclose: true,
        todayBtn: true,
        todayHighlight: true
    });

    $("#NgayEndFilter").on("blur", function () {
        if ($(this).val().trim() === "") {
            $(this).datepicker("setDate", null);
        }
    });
</script>