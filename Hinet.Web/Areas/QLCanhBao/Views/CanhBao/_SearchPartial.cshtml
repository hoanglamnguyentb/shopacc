
<style>
    .search {
        display: inline-block;
        position: relative;
        margin-bottom: 16px;
    }

        .search input[type="text"] {
            width: 350px;
            padding: 10px;
            border: none;
            border-radius: 20px !important;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

    .btn-search {
        background-color: #4e99e9;
        border: none;
        color: #fff;
        cursor: pointer;
        padding: 10px 20px;
        border-radius: 20px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        position: absolute;
        top: 0;
        right: 0;
        transition: .9s ease;
    }

    .btn-search:hover {
        transform: scale(1.1);
        color: rgb(255, 255, 255);
        background-color: blue;
    }
    #input-search {
        border: 1px solid lightskyblue;
    }

    .icon_img {
        width: 20px;
        margin-left: 5px;
    }
</style>

<div class="search ">
    <input placeholder="Nhập mã hoặc tên." type="text" id="input-search">
    <div class="btn-search">Tìm kiếm <img src="~/Uploads/Anh/icon-search.png" alt="" class="icon_img" /></div>
</div>

