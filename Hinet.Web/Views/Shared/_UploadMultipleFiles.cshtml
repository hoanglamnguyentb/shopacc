@using Hinet.Model.Entities;
@model IEnumerable<TaiLieuDinhKem>
<link href="~/Content/LibUploadFile/uploadfile.css" rel="stylesheet">
<script src="~/Content/LibUploadFile/jquery.uploadfile.js"></script>
@{
    string itemType = string.Empty;
    string label = "File đính kèm";
    string callBack = "";
    bool IsDetail = false;

    if (ViewData["ITEM_TYPE"] != null)
    {
        itemType = ViewData["ITEM_TYPE"].ToString();
    }
    if (ViewData["LABEL"] != null)
    {
        label = ViewData["LABEL"].ToString();
    }

    if (ViewData["CALL_BACK"] != null)
    {
        callBack = ViewData["CALL_BACK"].ToString();
    }
    if (ViewData["IS_DETAIL"] != null)
    {
        IsDetail = Convert.ToBoolean(ViewData["IS_DETAIL"]);
    }
}
<style>
    .ajax-file-upload-filename {
        max-width: 300px;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: inline-block;
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 2;
        word-wrap: break-word;
        overflow: hidden;
        margin-right: 20px;
        line-height: 2.8;
    }

    .text-white {
        color: white !important;
    }
</style>
<section class="uploadMulti wf100" style="">
    <label class="label control-label">
        <b>@label</b>
    </label>
    @if (IsDetail)
    {
    <div class="wf100">
        @if (Model != null && Model.Any())
            {
        <div class="boxUploads wf100">

            @{var idx = 1;}
            @foreach (var item in Model)
                    {
            <div class="ajax-file-upload-container ROW_TAILIEU" id="ROW_TAILIEU_@item.Id" data-file-name="@item.TenTaiLieu">
                <div class="ajax-file-upload-statusbar" style="width: inherit;border:1px solid #808080;">
                    <div class="ajax-file-upload-filename">
                        <span>@idx</span>
                        @item.TenTaiLieu
                    </div>
                    <div class="ajax-file-upload-progress" style="">
                        <div class="ajax-file-upload-bar" style="width: 100%;"></div>
                    </div>
                    <a target="_blank" title="Tải xuống" class="text-white ajax-file-upload-green" href="/Uploads/@item.DuongDanFile" download><i class="glyphicon glyphicon-save"></i></a>
                    <a title="Xem tài liệu" class="text-white ajax-file-upload-green" href="javascript:onPreview(@item.Id)"><i class="glyphicon glyphicon-exclamation-sign"></i></a>
                </div>
            </div>
                        idx += 1;
                    }
        </div>
            }
    </div>
    }
    else
    {
    <div class="fileuploader">Upload</div>
    <input type="hidden" name="fileuploadnames_" class="fileuploadnames_" />
    <div class="wf100">
        @if (Model != null && Model.Any())
            {
        <div class="boxUploads wf100">

            @{var idx = 1;}
            @foreach (var item in Model)
                    {
            <div class="ajax-file-upload-container ROW_TAILIEU" id="ROW_TAILIEU_@item.Id" data-file-name="@item.TenTaiLieu">
                <div class="ajax-file-upload-statusbar" style="width: inherit;border:1px solid #808080;">
                    <div class="ajax-file-upload-filename">
                        <span>@idx</span>
                        @item.TenTaiLieu
                    </div>
                    <div class="ajax-file-upload-progress" style="">
                        <div class="ajax-file-upload-bar" style="width: 100%;"></div>
                    </div>
                    <a target="_blank" title="Tải xuống" class="text-white ajax-file-upload-green" href="/Uploads/@item.DuongDanFile" download><i class="glyphicon glyphicon-save"></i></a>
                    <a href="javascript:onDeleteFile(@item.Id,'@item.TenTaiLieu')" class="ajax-file-upload-red text-white" title="Xóa tài liệu"><i class="bi bi-x-lg"></i> </a>
                    <a title="Xem tài liệu" class="text-white ajax-file-upload-green" href="javascript:onPreview(@item.Id)"><i class="glyphicon glyphicon-exclamation-sign"></i></a>
                </div>
            </div>
                        idx += 1;
                    }
        </div>
            }
    </div>
    }
</section>

<script>

    /**
     * xóa file
     * param dom: mã file để xóa
     */
    function onDeleteFile(dom, filename) {
        /**
         * trường hợp xóa file trong cơ sở dữ liệu
         */
        if (typeof dom === 'number') {
            var callBack = function () {
                $('#ROW_TAILIEU_' + dom).remove();
                var tenTaiLieu = $('#ROW_TAILIEU_' + dom).data('file-name');
                var StrFileNames = $(".fileuploadnames_").val();
                var TmpNames = StrFileNames.split('#');
                TmpNames.splice($.inArray(tenTaiLieu, TmpNames), 1);
                var CurrNames = "";
                for (var i = 0; i < TmpNames.length; i++) {
                    if (TmpNames[i] != undefined && TmpNames[i] != "") {
                        CurrNames += "#" + TmpNames[i];
                    }
                }
                $("#UploadFiles").val(LstFileNames);
                $(".fileuploadnames_").val(CurrNames);
                if ('@callBack' !== '' && typeof window['@callBack'] === 'function') {
                    window["@callBack"]();
                }
            };

            var url = '/Common/DeleteFile';
            var params = { id: dom };
            var type = 'post';
            var title = 'Xác nhận xóa file';
            var content = 'Bạn có chắc chắn muốn xóa file';
            onConfirmCallAjax(url, type, params, callBack, title, content);
        } else {
            var row = dom.closest('tr');
            row.remove(row.selectedIndex);
        }
    }

    $(document).ready(function () {
        $(".fileuploader").uploadFile({
            url: "/Common/UploadMultipleFiles?itemType=@itemType",
            showDelete: true,
            showDownload: true,
            //showViewFile: true,
            deleteStr: "Xóa",
            //viewfileStr: "Xem file",
            dragdropWidth: "inherit",
            statusBarWidth: "inherit",
            deleteCallback: function (data, pd) {
                for (var i = 0; i < data.length; i++) {
                    $.post("/Common/DeleteTempFile?itemType=@itemType", { name: data[i] },
                        function (resp, textStatus, jqXHR) {
                            var StrFileNames = $(".fileuploadnames_").val();
                            var TmpNames = StrFileNames.split('#');
                            NotiSuccess("Xóa thành công");
                            TmpNames.splice($.inArray(resp.Message, TmpNames), 1);
                            var CurrNames = "";
                            for (var i = 0; i < TmpNames.length; i++) {
                                if (TmpNames[i] != undefined && TmpNames[i] != "") {
                                    CurrNames += "#" + TmpNames[i];
                                }
                            }
                            $(".fileuploadnames_").val(CurrNames)
                            if ('@callBack' !== '' && typeof window['@callBack'] === 'function') {
                                window["@callBack"]();
                            }
                        });
                }
                pd.statusbar.hide(); //You choice.

            },
            downloadCallback: function (filename, pd) {
                window.open('/Uploads/Temp/@itemType/' + filename);
            },
            //viewfileCallback: function (filename, pdf) {

            //},
            onSuccess: function (files, data, xhr, pd) {
                //files: list of files
                //data: response from server
                //xhr : jquer xhr object
                var LstFileNames = $(".fileuploadnames_").val();
                for (var i = 0; i < data.length; i++) {
                    LstFileNames += "#" + data[i];
                }
                $(".fileuploadnames_").val(LstFileNames);
                $("#UploadFiles").val(LstFileNames);
                if ('@callBack' !== '' && typeof window['@callBack'] === 'function') {
                    window["@callBack"]();
                }
            }
        });
    });

        @*function onPreview(id) {
        OpenModalPreview('/Common/PreviewFile?itemType=@itemType', { id: id }, 'post');
    }*@

