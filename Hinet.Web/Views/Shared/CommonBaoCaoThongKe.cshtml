@using Hinet.Service.Common
@using CommonHelper.String
@using Newtonsoft.Json
@model ChartModuleWraper
@{
    var codeRdOfModule = StringUtilities.GenerateCoupon(5);
    var DataChart = Html.Raw(JsonConvert.SerializeObject(Model.chartDtos));
}
<div class="row">
    <div class="col-sm-6">
        <div class="headerBaoCao">Bảng thống kê @Model.title</div>
        @if (Model.chartDtos != null)
        {
        <table class="table table-info">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>@Model.TextOfLabel</th>
                    <th>@Model.TextOfData</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.chartDtos)
                    {
                <tr>
                    <td>@(Model.chartDtos.IndexOf(item)+1)</td>
                    <td>@item.Label</td>
                    <td>@item.data</td>
                </tr>
                    }
            </tbody>
        </table>
        }
    </div>
    <div class="col-sm-6">
        <div class="headerBaoCao">Biểu đồ @Model.title</div>
        @if (Model.chartDtos != null)
        {
        <div>
            <div id="@Model.KeyModuleChartJs">
            </div>
        </div>
        }
    </div>
</div>

<script>

    var options = {
        series:
            [{
                data:eval(`@DataChart`)
            }]
            ,
        chart: {
            type: 'bar',
            height: 350
        },
        plotOptions: {
            bar: {
                horizontal: false,
                columnWidth: '55%',
                endingShape: 'rounded'
            },
        },
        dataLabels: {
            enabled: false
        },
        stroke: {
            show: true,
            width: 2,
            colors: ['transparent']
        },
        //xaxis: {
        //    categories: arrNam,
        //},
        yaxis: {
            title: {
                text: ' @Model.TextOfData'
            },
            labels: {
                formatter: (value) => { return formatNumber(value, "", ".", true) },
            }
        },
        fill: {
            opacity: 1
        },
        tooltip: {
            y: {
                formatter: function (val) {
                    return ToNumber(val) + " @Model.TextOfData"
                }
            }
        }
    };

    var chart = new ApexCharts(document.querySelector("#"+"@Model.KeyModuleChartJs"), options);
    chart.render();
</script>