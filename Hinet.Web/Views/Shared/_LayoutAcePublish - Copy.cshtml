    @using Hinet.Service.AppUserService.Dto
    @using Microsoft.AspNet.Identity
    @using Hinet.Service.Constant

    @{
        var userInfo = SessionManager.GetUserInfo() as UserDto;
        long jsUserId = 0;
        if (userInfo != null)
        {

            jsUserId = userInfo.Id;
        }
    }
    <div class="main-container ace-save-state LayoutPublish" id="main-container">
        <script type="text/javascript">
            try { ace.settings.loadState('main-container') } catch (e) { }
        </script>


        <div class="main-content">
            <div class="main-content-inner">
                <div class="page-content">
                    @*@Html.Partial("_ConfigThemePartial")*@
                    <!-- /.ace-settings-container -->

                    <div class="page-header">
                        <h1>
                            @ViewBag.ModuleName
                            <small>
                                <i class="ace-icon fa fa-angle-double-right"></i>
                                @ViewBag.PageName
                            </small>
                        </h1>
                        <div class="action-right-bar">
                            @RenderSection("ActionBarRight", false)
                        </div>

                    </div><!-- /.page-header -->
                    <div class="Body_LayoutPublish">
                        @RenderBody()
                    </div>
                    <div id="MasterModalFixed" class="modal fade">
                    </div>
                    <div id="MasterModal" class="modal fade" role="dialog">
                    </div>
                </div><!-- /.page-content -->
            </div>
        </div><!-- /.main-content -->
        @*@Html.Partial("_FooterPartial")*@
        <a href="#" id="btn-scroll-up" onclick="scroll()" class="btn-scroll-up btn btn-sm btn-inverse">
            <i class="ace-icon fa fa-angle-double-up icon-only bigger-110"></i>
        </a>
    </div>

    <script src="/Scripts/jquery.signalR-2.4.1.min.js">
    </script>

    <script src="/signalr/hubs">
    </script>

    <script>
        var jsUserId = parseInt(eval('@jsUserId'));
        var typeAcc = '@AccountTypeConstant.BussinessUser'
        $(document).ready(function() {
        $(".table-scroll .hinet-table").clone(true).appendTo('.table-scroll').addClass('clone');

        var endofTextRun = function () {
        $("#boxRunText").empty();
        }

        $("#nav-search-input").keyup(function () {
        var key = $(this).val();
        AjaxCall("/dashboardArea/dashboard/SearchCommon?key=" + key, 'get', null, function (rs) {
        $("#boxResultContainer").html(rs);
        }, function () {

        })
        });
        $(document).ready(function () {
        setInterval(function () {
        var firstItemNoti = $("#boxRunText .textItem.active").each(function () {
        $(this).remove();
        });
        showBroadcastNoti();
        }, 10000)
        });

        $(document)
        .ajaxStart(function () {
        $("#hinet-preloader").css("display", "block");
        })
        .ajaxStop(function () {
        $("#hinet-preloader").css("display", "none");
        });

        $(window).scroll(function (event) {
        var scroll = $(window).scrollTop();
        if (scroll >45 ) {
        $("#sidebar").addClass("fixtop0");
        $(".btn-scroll-up").css("display","block")
        }else{
        $(".btn-scroll-up").css("display","none")
        $("#sidebar").removeClass("fixtop0");
        }
        });

        });

        var full_path = location.href.split("#")[0];
        $(".no-skin .nav-list > li .submenu > li > a").each(function () {
        var $this = $(this);
        if ($this.prop("href").split("#")[0] == full_path) {
        $(this).parent().addClass("active_trail");
        }
        });
    </script>

    <script src="~/Scripts/ThongBaoHub.js">
    </script>
    @RenderSection("scripts", required: false)

    @Html.Partial("_addMenuPartial")
    <script src="~/assets/js/jquery.colorbox.min.js">
    </script>

</body>
</html>
